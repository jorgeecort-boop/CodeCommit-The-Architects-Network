# CodeCommit Environment Variables
# Copia este archivo como .env y completa los valores

# JWT Configuration
CODECOMMIT_JWT_SECRET=your-secret-key-here
CODECOMMIT_JWT_TTL=86400

# App Version
CODECOMMIT_APP_VERSION=5.7

# Database
DATABASE_URL=sqlite:////app/data/codecommit.db

# Admin Access
CODECOMMIT_ADMIN_DASH_SECRET=your-admin-secret
CODECOMMIT_ADMIN_BOOTSTRAP_KEY=your-bootstrap-key

# Rate Limiting
CODECOMMIT_RATE_LIMIT_MAX=60
CODECOMMIT_RATE_LIMIT_WINDOW_SECONDS=60

# GitHub OAuth (obtén en https://github.com/settings/developers)
CODECOMMIT_GITHUB_CLIENT_ID=
CODECOMMIT_GITHUB_CLIENT_SECRET=
CODECOMMIT_GITHUB_REDIRECT_URI=http://your-domain/v2/auth/github/callback
CODECOMMIT_GITHUB_OAUTH_SCOPE=read:user user:email
CODECOMMIT_GITHUB_STATE_TTL_SECONDS=600
