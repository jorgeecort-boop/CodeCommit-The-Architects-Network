# CodeCommit Environment Variables
# Copy this file to .env and fill in the values

# JWT Secret - GENERATE A SECURE VALUE: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-secure-jwt-secret-here

# Admin Dashboard Secret
ADMIN_DASH_SECRET=your-admin-dashboard-secret

# Optional: GitHub OAuth (for GitHub login feature)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_REDIRECT_URI=https://74.208.227.87/v2/auth/github/callback
